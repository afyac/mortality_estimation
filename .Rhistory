ggplot2::geom_point() +
ggplot2::geom_smooth(se = FALSE, span = 0.9, data = data |> dplyr::filter(date >= as.Date(DATE_FORECAST))) +
ggplot2::geom_smooth(data = data |> dplyr::filter(date <= as.Date(DATE_FORECAST)), color = "darkred", span = 0.2, se = FALSE) +
ggplot2::geom_point(data = data |> dplyr::filter(date <= as.Date(DATE_FORECAST)), color = "black") +
