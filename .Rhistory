dplyr::select(date, pred, dr, p_time)
ts_all <- list(pess_data, stat_data,opt_data, real_data)
ts_all[[1]]$scen <- 'pess_data'
ts_all[[2]]$scen <- 'stat_data'
ts_all[[3]]$scen <- 'opt_data'
